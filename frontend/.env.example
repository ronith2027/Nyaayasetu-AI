# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional separate auth API (e.g. AWS API Gateway URL)
# If set, signup/login will automatically call this instead of NEXT_PUBLIC_API_URL
NEXT_PUBLIC_AUTH_API_URL=

# Application Configuration
NEXT_PUBLIC_APP_NAME=NyayaSetu AI
NEXT_PUBLIC_APP_DESCRIPTION=Rural Legal Access Platform

# Feature Flags
NEXT_PUBLIC_ENABLE_VECTOR_SEARCH=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
