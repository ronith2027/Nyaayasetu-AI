# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Auth Service Database Configuration
AUTH_DB_HOST=localhost
AUTH_DB_USER=root
AUTH_DB_PASSWORD=your-auth-db-password
AUTH_DB_NAME=nyaaya_auth

# User Data Service Database Configuration
USER_DATA_DB_HOST=localhost
USER_DATA_DB_USER=root
USER_DATA_DB_PASSWORD=your-user-data-db-password
USER_DATA_DB_NAME=nyaaya_user_data

# AWS OpenSearch Configuration
OPENSEARCH_ENDPOINT=https://your-opensearch-domain.us-east-1.es.amazonaws.com
OPENSEARCH_USERNAME=your-opensearch-username
OPENSEARCH_PASSWORD=your-opensearch-password
OPENSEARCH_INDEX=user-data-vectors
EMBEDDING_DIMENSION=1536

# AWS Configuration (if using AWS services)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT_URL=https://x8eaonh7x2.execute-api.ap-south-1.amazonaws.com # optional, e.g. for DynamoDB Local
DYNAMODB_TABLE_USERS=Users
DYNAMODB_TABLE_CHATS=UserChats
DYNAMODB_TABLE_USER_FORMS=UserForms
DYNAMODB_TABLE_USER_DOCUMENTS=UserDocuments

# Auth storage mode
AUTH_USE_DYNAMODB=1 # set to 1 to store users in DynamoDB instead of MySQL

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Google Maps / Places API (for locator if used on backend)
GOOGLE_MAPS_API_KEY=AIzaSyAYuAWsxVqcmID3Y02nu_up10yevRX19Tg
