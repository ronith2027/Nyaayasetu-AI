# Example .env file for NyaayaSetu-AI backend
# Enable DynamoDB mode
AUTH_USE_DYNAMODB=1

# AWS configuration (replace with your actual credentials or use IAM role)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
# Optional session token if using temporary credentials
# AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN

# DynamoDB table names (ensure these tables exist in your AWS account)
DYNAMODB_TABLE_USERS=Users
DYNAMODB_TABLE_CHATS=UserChats

# JWT secret for token signing (use a strong secret in production)
JWT_SECRET=super-secret-key

# MySQL fallback configuration (used when AUTH_USE_DYNAMODB=0)
AUTH_DB_HOST=localhost
AUTH_DB_USER=root
AUTH_DB_PASSWORD=
AUTH_DB_NAME=nyaaya_auth
